#!/bin/bash
# Create flash token on Base
# Usage: create-flash-token-base --token-name "My Token" --symbol "MTK" [options]

set -e

show_help() {
  echo "Usage: create-flash-token-base [options]"
  echo ""
  echo "Options:"
  echo "  --token-name <name>         Token name (required)"
  echo "  --symbol <symbol>           Token symbol (required)"
  echo "  --initial-supply <amount>   Total supply (default: 1000000)"
  echo "  --logo <path>               Logo path (default: ./assets/placeholder.png)"
  echo "  --twitter <url>             Twitter URL"
  echo "  --telegram <url>            Telegram URL"
  echo "  --website <url>             Website URL"
  echo "  --discord <url>             Discord URL"
  echo "  --description <text>        Token description"
  echo "  --fee-tier <bps>            Dex fee tier in bps (default: 3)"
  echo "  --liquidity-fee <bps>       Liquidity fee in bps (default: 1)"
  echo "  --buyback-fee <bps>         Buyback fee in bps (default: 1)"
  echo "  --reward-token <token>      Reward token symbol (default: ETH)"
  echo "  --min-balance <amount>      Min token balance for dividends (default: 0.01)"
  echo "  --sandbox                   Enable sandbox mode"
  echo "  --no-sandbox                Disable sandbox mode (default)"
  echo "  --yes                       Skip transaction confirmation (for agents/demos)"
  echo "  --dry-run                  Validate and print payload without executing"
  echo "  --validate                 Validate schema only"
  echo ""
  echo "Environment:"
  echo "  SKIP_TX_CONFIRMATION=true   Skip all confirmations"
  echo ""
  echo "Example:"
  echo "  create-flash-token-base \\"
  echo "    --token-name \"My Token\" \\"
  echo "    --symbol \"MTK\""
}

# Parse known arguments, collect rest for passing through
TOKEN_NAME=""
SYMBOL=""
INITIAL_SUPPLY="1000000"
LOGO="./assets/placeholder.png"
TWITTER=""
TELEGRAM=""
WEBSITE=""
DISCORD=""
DESCRIPTION=""
FEE_TIER="3"
LIQUIDITY_FEE="1"
BUYBACK_FEE="1"
REWARD_TOKEN="ETH"
MIN_BALANCE="0.01"
SANDBOX_MODE="false"
SKIP_CONFIRM="false"
DRY_RUN="false"
VALIDATE_ONLY="false"
EXTRA_ARGS=()

while [[ $# -gt 0 ]]; do
  case $1 in
    --token-name) TOKEN_NAME="$2"; shift 2 ;;
    --symbol) SYMBOL="$2"; shift 2 ;;
    --initial-supply) INITIAL_SUPPLY="$2"; shift 2 ;;
    --logo) LOGO="$2"; shift 2 ;;
    --twitter) TWITTER="$2"; shift 2 ;;
    --telegram) TELEGRAM="$2"; shift 2 ;;
    --website) WEBSITE="$2"; shift 2 ;;
    --discord) DISCORD="$2"; shift 2 ;;
    --description) DESCRIPTION="$2"; shift 2 ;;
    --fee-tier) FEE_TIER="$2"; shift 2 ;;
    --liquidity-fee) LIQUIDITY_FEE="$2"; shift 2 ;;
    --buyback-fee) BUYBACK_FEE="$2"; shift 2 ;;
    --reward-token) REWARD_TOKEN="$2"; shift 2 ;;
    --min-balance) MIN_BALANCE="$2"; shift 2 ;;
    --sandbox) SANDBOX_MODE="true"; shift ;;
    --no-sandbox) SANDBOX_MODE="false"; shift ;;
    --yes) SKIP_CONFIRM="true"; shift ;;
    --dry-run) DRY_RUN="true"; EXTRA_ARGS+=("$1"); shift ;;
    --validate) VALIDATE_ONLY="true"; EXTRA_ARGS+=("$1"); shift ;;
    --help|-h) show_help; exit 0 ;;
    *) EXTRA_ARGS+=("$1"); shift ;;
  esac
done

# Check env var for skip confirmation
if [[ "$SKIP_CONFIRM" == "true" ]]; then
  export SKIP_TX_CONFIRMATION="true"
fi
 
# Build config with JSON.stringify so user-provided text is escaped safely.
CONFIG="$(
  TOKEN_NAME="$TOKEN_NAME" \
  SYMBOL="$SYMBOL" \
  INITIAL_SUPPLY="$INITIAL_SUPPLY" \
  LOGO="$LOGO" \
  TWITTER="$TWITTER" \
  TELEGRAM="$TELEGRAM" \
  WEBSITE="$WEBSITE" \
  DISCORD="$DISCORD" \
  DESCRIPTION="$DESCRIPTION" \
  FEE_TIER="$FEE_TIER" \
  LIQUIDITY_FEE="$LIQUIDITY_FEE" \
  BUYBACK_FEE="$BUYBACK_FEE" \
  REWARD_TOKEN="$REWARD_TOKEN" \
  MIN_BALANCE="$MIN_BALANCE" \
  SANDBOX_MODE="$SANDBOX_MODE" \
  node <<'NODE'
const number = (name) => {
  const value = Number(process.env[name]);
  if (!Number.isFinite(value)) {
    console.error(`Error: ${name} must be a valid number`);
    process.exit(1);
  }
  return value;
};

const config = {
  isSandboxMode: process.env.SANDBOX_MODE === 'true',
  package: 'based',
  chainId: 8453,
  token: {
    name: process.env.TOKEN_NAME,
    symbol: process.env.SYMBOL,
    totalSupply: number('INITIAL_SUPPLY'),
    initialBuyAmount: 0,
    metadata: {
      logo: process.env.LOGO,
      twitter: process.env.TWITTER,
      telegram: process.env.TELEGRAM,
      website: process.env.WEBSITE,
      discord: process.env.DISCORD,
      description: process.env.DESCRIPTION,
    },
  },
  dex: {
    version: 'uniswap_v4',
    feeTier: number('FEE_TIER'),
  },
  fees: {
    v4: {
      liquidity: number('LIQUIDITY_FEE'),
      buyback: number('BUYBACK_FEE'),
      reward: {
        token: process.env.REWARD_TOKEN,
        amount: 1,
        minTokenBalanceForDividends: number('MIN_BALANCE'),
      },
      customWallets: [],
      feeThreshold: 0.1,
      tieredFeesEnabled: false,
      dynamicFees: {
        hasHookDynamicFee: true,
        volatilityDecayPeriod: 'medium',
        volatilityMultiplier: 'medium',
        volatilityTrigger: 'per_block',
      },
      cooldownProtection: {
        cooldownDuration: 'medium',
        penaltyFee: 'medium',
      },
      buyLimits: {
        protectPeriod: 600,
        maxBuyPerOrigin: 5,
        isHookWhitelist: false,
      },
      mevProtectionEnabled: true,
    },
  },
};

process.stdout.write(JSON.stringify(config, null, 2));
NODE
)"

# Resolve symlinks so globally installed commands run from the cloned repo.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
REPO_DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
cd "$REPO_DIR" || exit 1

if [[ ! -d "node_modules" ]]; then
  echo "Error: node_modules not found. Run ./install.sh first." >&2
  exit 1
fi

# Create temp config
TEMP_CONFIG=$(mktemp)
trap 'rm -f "$TEMP_CONFIG"' EXIT
echo "$CONFIG" > "$TEMP_CONFIG"

echo "Creating flash token on Base..."
echo "Token: $TOKEN_NAME ($SYMBOL)"
echo ""

# Confirm if not sandbox mode and not skipping confirmation
if [[ "$SANDBOX_MODE" == "false" && "$SKIP_CONFIRM" == "false" && "$DRY_RUN" == "false" && "$VALIDATE_ONLY" == "false" ]]; then
  echo "WARNING: This will submit a LIVE transaction on Base mainnet."
  read -p "Continue? (y/N) " -n 1 -r
  echo ""
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 1
  fi
fi

npm run evm:create-flash-token -- "$TEMP_CONFIG" "${EXTRA_ARGS[@]}"
