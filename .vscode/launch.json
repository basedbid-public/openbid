{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Solana: create-lbp",
      "program": "${workspaceFolder}/src/helpers/run.ts",
      "runtimeArgs": [
        "-r",
        "ts-node/register",
        "-r",
        "tsconfig-paths/register"
      ],
      "args": [
        "solana-create-lbp",
        "./src/helpers/configs/solana/create-lbp.json"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "EVM: create-lbp (dry-run)",
      "program": "${workspaceFolder}/src/helpers/run.ts",
      "runtimeArgs": [
        "-r",
        "ts-node/register",
        "-r",
        "tsconfig-paths/register"
      ],
      "args": [
        "evm-create-lbp",
        "./src/helpers/configs/evm/create-lbp.json",
        "--dry-run"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "EVM: create-flash-token",
      "program": "${workspaceFolder}/src/helpers/run.ts",
      "runtimeArgs": [
        "-r",
        "ts-node/register",
        "-r",
        "tsconfig-paths/register"
      ],
      "args": [
        "evm-create-flash-token",
        "./src/helpers/configs/evm/create-flash-token.json"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
