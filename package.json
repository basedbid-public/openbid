{
  "name": "openbid",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test:skill": "node --test tests/*.test.mjs",
    "validate:solana-example": "ts-node ./src/helpers/run.ts solana-create-lbp ./src/helpers/configs/solana/create-lbp.json --validate",
    "check": "npm run build && npm run test:skill && npm run validate:solana-example",
    "format": "prettier --write src/",
    "wallet:evm": "ts-node ./src/scripts/generate-wallet/evm.ts",
    "wallet:solana": "ts-node ./src/scripts/generate-wallet/solana.ts",
    "evm:create-lbp": "ts-node  ./src/helpers/run.ts evm-create-lbp ./src/helpers/configs/evm/create-lbp.json",
    "evm:create-board": "ts-node  ./src/helpers/run.ts evm-create-board ./src/helpers/configs/evm/create-board.json",
    "evm:create-flash-token": "ts-node  ./src/helpers/run.ts evm-create-flash-token ./src/helpers/configs/evm/create-flash-token.json",
    "evm:lbp-buy": "ts-node  ./src/helpers/run.ts evm-lbp-buy ./src/helpers/configs/evm/lbp-buy.json",
    "evm:lbp-sell": "ts-node  ./src/helpers/run.ts evm-lbp-sell ./src/helpers/configs/evm/lbp-sell.json",
    "evm:claim-fees": "ts-node  ./src/helpers/run.ts evm-claim-fees ./src/helpers/configs/evm/claim-fees.json",
    "solana:create-lbp": "ts-node  ./src/helpers/run.ts solana-create-lbp ./src/helpers/configs/solana/create-lbp.json",
    "solana:create-board": "ts-node  ./src/helpers/run.ts solana-create-board ./src/helpers/configs/solana/create-board.json",
    "solana:create-flash-token": "ts-node  ./src/helpers/run.ts solana-create-flash-token ./src/helpers/configs/solana/create-flash-token.json",
    "solana:lbp-buy": "ts-node  ./src/helpers/run.ts solana-lbp-buy ./src/helpers/configs/solana/lbp-buy.json",
    "solana:lbp-sell": "ts-node  ./src/helpers/run.ts solana-lbp-sell ./src/helpers/configs/solana/lbp-sell.json",
    "solana:claim-lbp-fees": "ts-node  ./src/helpers/run.ts solana-claim-lbp-fees ./src/helpers/configs/solana/claim-lbp-fees.json",
    "solana:claim-flash-fees": "ts-node  ./src/helpers/run.ts solana-claim-flash-fees ./src/helpers/configs/solana/claim-flash-token-fees.json"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "^17.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-organize-imports": "4.3.0",
    "ts-node": "10.9.2",
    "tsc-alias": "1.9.0",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "@inquirer/prompts": "8.5.2",
    "@solana/kit": "7.0.0",
    "bs58": "6.0.0",
    "dotenv": "17.4.2",
    "ethers": "6.17.0",
    "viem": "2.55.1",
    "zod": "4.4.3"
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
